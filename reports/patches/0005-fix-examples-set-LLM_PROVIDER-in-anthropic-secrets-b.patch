From 75646765aae834862276c78dc863b6e8565fda3c Mon Sep 17 00:00:00 2001
From: addnad <postaddnad@gmail.com>
Date: Sat, 4 Jul 2026 09:41:44 +0000
Subject: [PATCH 5/5] fix(examples): set LLM_PROVIDER in anthropic secrets
 branch

The OpenAI/Gemini/OpenRouter branches include LLM_PROVIDER in
SECRETS_JSON but the Anthropic branch did not; make it explicit for
consistency.
---
 examples/sovereign-agent/run.sh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/examples/sovereign-agent/run.sh b/examples/sovereign-agent/run.sh
index 9b64f8f..d1161e2 100755
--- a/examples/sovereign-agent/run.sh
+++ b/examples/sovereign-agent/run.sh
@@ -133,7 +133,7 @@ if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
     SECRETS_JSON=$("${PY[@]}" - <<'PY'
 import json
 import os
-print(json.dumps({"ANTHROPIC_API_KEY": os.environ["ANTHROPIC_API_KEY"], "HF_TOKEN": os.environ["HF_TOKEN"]}))
+print(json.dumps({"LLM_PROVIDER": "anthropic", "ANTHROPIC_API_KEY": os.environ["ANTHROPIC_API_KEY"], "HF_TOKEN": os.environ["HF_TOKEN"]}))
 PY
 )
 elif [ -n "${OPENAI_API_KEY:-}" ]; then
-- 
